{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "aliyun-codeup-raycast",
  "title": "Aliyun Codeup",
  "description": "Search Ali YunXiao Code Project",
  "icon": "extension-icon.png",
  "author": "kejiang",
  "owner": "ali-yun-xiao",
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "codeup",
      "title": "Codeup",
      "subtitle": "Aliyun Codeup Search",
      "description": "Aliyun Codeup",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "organizationId",
      "type": "textfield",
      "title": "Organization ID",
      "description": "组织 ID，用于访问 API",
      "placeholder": "访问 https://account-devops.aliyun.com/settings/joinedOrganizations 获取",
      "required": true
    },
    {
      "name": "accessToken",
      "type": "textfield",
      "title": "Access Token",
      "description": "借助 Token 访问 API",
      "placeholder": "访问 https://account-devops.aliyun.com/settings/personalAccessToken 获取",
      "required": true
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.103.3",
    "@raycast/utils": "^2.2.1",
    "@yuntoo/aliyun-codeup-open-api": "1.0.3"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "24.8.1",
    "@types/react": "19.2.2",
    "eslint": "^9.38.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"\\n\\nIt seems like you are trying to publish the Raycast extension to npm.\\n\\nIf you did intend to publish it to npm, remove the \\`prepublishOnly\\` script and rerun \\`npm publish\\` again.\\nIf you wanted to publish it to the Raycast Store instead, use \\`npm run publish\\` instead.\\n\\n\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  }
}
